// Reco Video Stitcher - GUI
// Material dark theme (configured via build.rs)

import { Button, VerticalBox, HorizontalBox, Slider, ProgressIndicator, LineEdit, ComboBox, CheckBox, ScrollView, TabWidget, Palette, StyleMetrics } from "std-widgets.slint";

/// One labeled slider row for the controls panel.
component LabeledSlider inherits VerticalLayout {
    in property <string> label;
    in property <float> minimum;
    in property <float> maximum;
    in-out property <float> value;
    in property <string> suffix: "";
    in property <int> decimals: 2;
    callback changed(float);

    spacing: 2px;

    HorizontalLayout {
        Text {
            text: root.label;
            color: #bbb;
            font-size: 11px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        Text {
            property <float> scale:
                root.decimals <= 0 ? 1
              : root.decimals == 1 ? 10
              : root.decimals == 2 ? 100
              : root.decimals == 3 ? 1000
              : root.decimals == 4 ? 10000
              : 100000;
            text: (root.decimals == 0
                ? round(root.value)
                : round(root.value * scale) / scale) + root.suffix;
            color: #888;
            font-size: 11px;
            vertical-alignment: center;
        }
    }

    Slider {
        minimum: root.minimum;
        maximum: root.maximum;
        value <=> root.value;
        changed(v) => { root.changed(v); }
    }
}

/// Collapsible section header with clear hover feedback.
component SectionHeader inherits Rectangle {
    in property <string> title;
    in-out property <bool> expanded: false;

    height: 30px;
    border-radius: 4px;
    background: section-touch.has-hover ? #2e2e2e : #1e1e1e;

    section-touch := TouchArea {
        clicked => { root.expanded = !root.expanded; }
        mouse-cursor: pointer;
    }

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 6px;

        Text {
            text: root.expanded ? "▾" : "▸";
            color: root.expanded ? #aaa : #666;
            font-size: 11px;
            vertical-alignment: center;
            width: 14px;
        }
        Text {
            text: root.title;
            color: #eee;
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

// Toast notification payload. Kept flat (no nested structs) so the
// Rust side can push via the generated `VecModel<Toast>` without
// wrapping ceremony. `id` is an opaque Rust-side counter used as the
// dismissal handle; UI code doesn't interpret it.
export struct Toast {
    id: int,
    severity: string, // "info" | "warn" | "error"
    title: string,
    body: string,
}

/// A single dismissible toast card. Stacked vertically by `ToastStack`.
///
/// Severity drives the left-border accent color:
/// - info: blue-grey
/// - warn: amber
/// - error: red
/// All three share the same dark card background to match the app chrome.
component ToastCard inherits Rectangle {
    in property <Toast> toast;
    callback dismissed(int);

    height: content.preferred-height + 16px;
    width: 360px;
    border-radius: 6px;
    background: #1f1f1f;
    border-width: 1px;
    border-color: #333;
    // Severity accent via left-edge bar (drawn with a clipped child
    // rectangle below). Also shifts the main border color subtly.
    drop-shadow-blur: 6px;
    drop-shadow-color: #000000aa;

    Rectangle {
        x: 0; y: 0;
        width: 4px;
        height: parent.height;
        background: root.toast.severity == "error" ? #e06060
                  : root.toast.severity == "warn"  ? #e0c060
                  : #6080c0;
    }

    content := HorizontalLayout {
        padding-left: 14px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 8px;

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.toast.title;
                color: #fff;
                font-size: 12px;
                font-weight: 600;
                wrap: word-wrap;
            }
            if root.toast.body != "": Text {
                text: root.toast.body;
                color: #bbb;
                font-size: 11px;
                wrap: word-wrap;
            }
        }

        // Dismiss button. Kept narrow so the card body gets the space.
        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 10px;
            background: dismiss-touch.has-hover ? #3a3a3a : transparent;
            Text {
                text: "×";
                color: #888;
                font-size: 16px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            dismiss-touch := TouchArea {
                clicked => { root.dismissed(root.toast.id); }
            }
        }
    }
}

/// Bottom-right stack of toast cards. Spawns a `ToastCard` per entry
/// in `toasts` and forwards dismissal back to the consumer via the
/// `dismissed(id)` callback.
component ToastStack inherits Rectangle {
    in property <[Toast]> toasts;
    in property <length> right-inset: 0px;
    callback dismissed(int);

    VerticalLayout {
        x: parent.width - self.preferred-width - 16px - root.right-inset;
        y: parent.height - self.preferred-height - 16px;
        spacing: 8px;
        alignment: end;

        for toast in root.toasts: ToastCard {
            toast: toast;
            dismissed(id) => { root.dismissed(id); }
        }
    }
}

export component RecoApp inherits Window {
    title: "Reco Video Stitcher";
    preferred-width: 1280px;
    preferred-height: 820px;
    min-width: 720px;
    min-height: 600px;

    // ── Theme colors ──
    in-out property <bool> dark-mode: true;

    property <color> bg-base: dark-mode ? #121212 : #f5f5f5;
    property <color> bg-panel: dark-mode ? #1a1a1a : #eaeaea;
    property <color> bg-bar: dark-mode ? #1e1e1e : #e0e0e0;
    property <color> bg-surface: dark-mode ? #222 : #fff;
    property <color> bg-card: dark-mode ? #242424 : #ddd;
    property <color> bg-hover: dark-mode ? #2e2e2e : #c8c8c8;
    property <color> bg-preview: dark-mode ? #0a0a0a : #444;
    property <color> bg-scrim: dark-mode ? #000000aa : #000000aa;
    property <color> border-subtle: dark-mode ? #333 : #ccc;
    property <color> border-mid: dark-mode ? #444 : #aaa;
    property <color> text-primary: dark-mode ? #eee : #111;
    property <color> text-body: dark-mode ? #ccc : #222;
    property <color> text-secondary: dark-mode ? #aaa : #333;
    property <color> text-muted: dark-mode ? #888 : #444;
    property <color> text-dim: dark-mode ? #666 : #555;
    property <color> text-faint: dark-mode ? #555 : #666;
    property <color> text-heading: dark-mode ? #fff : #111;
    property <color> accent: dark-mode ? #8ae68a : #2a7a2a;
    property <color> accent-info: dark-mode ? #8f8 : #2a8a2a;
    property <color> accent-warn: dark-mode ? #e8a060 : #c07020;
    property <color> accent-error: dark-mode ? #f88 : #c44;
    property <color> rec-bg: dark-mode ? #2a1a1a : #f0e0e0;
    property <color> rec-border: dark-mode ? #553333 : #c08080;
    property <color> rec-active-bg: dark-mode ? #4a1010 : #f0c0c0;
    property <color> rec-active-border: dark-mode ? #e04040 : #c03030;

    background: bg-base;

    // Preview area dimensions (Rust reads these to size the render target).
    out property <float> preview-area-width: preview-box.width / 1px;
    out property <float> preview-area-height: preview-box.height / 1px;

    // ── Properties bound from Rust ──

    in-out property <image> preview-frame;
    in-out property <bool> playing: false;
    in-out property <bool> files-loaded: false;
    in-out property <string> left-path: "";
    in-out property <string> right-path: "";
    in-out property <string> calibration-path: "";
    in-out property <string> status-text: "Load left + right videos and calibration JSON to begin";
    in-out property <float> progress: 0.0;
    in-out property <int> current-frame: 0;
    in-out property <int> total-frames: 0;
    in-out property <string> current-time-text: "0:00";
    in-out property <string> total-time-text: "0:00";
    in-out property <float> fps: 0.0;
    in-out property <bool> calibrating: false;
    in-out property <string> calibration-step: "";
    in-out property <bool> has-both-videos: left-path != "" && right-path != "";
    in-out property <bool> has-roi: false;
    in-out property <[float]> roi-points-x: [];
    in-out property <[float]> roi-points-y: [];
    callback launch-roi-editor();
    callback paste-roi();
    in-out property <string> roi-manual-json: "";

    // Camera view state (kept in sync with Rust AppState).
    in-out property <float> yaw: 0.0;      // radians
    in-out property <float> pitch: 0.0;    // radians
    in-out property <float> fov: 75.0;     // degrees
    in-out property <float> blend-width: 0.05;
    in-out property <float> rig-tilt: 0.0; // degrees
    in-out property <float> rig-roll: 0.0; // degrees
    in-out property <int> sync-offset: 0;  // frames

    // Live calibration adjustments (PlaneLayout fields on MatchCalibration).
    // Updating these re-runs StitchPipeline::update_layout() so the user
    // can fine-tune the stitch seam without re-running auto-calibrate.
    in-out property <float> cal-intersect: 0.0;
    in-out property <float> cal-camera-axis-offset: 0.0;
    in-out property <float> cal-x-ty: 0.0;
    in-out property <bool> cal-dirty: false;  // true when user has edited

    // Side panel visibility (unified Controls + Stats).
    in-out property <bool> controls-open: false;

    // Export dialog state.
    in-out property <bool> export-dialog-open: false;
    in-out property <string> export-output-path: "";
    in-out property <int> export-width: 1920;
    in-out property <int> export-height: 1080;
    in-out property <string> export-codec: "h264";
    in-out property <[string]> available-codecs: ["h264", "hevc", "av1"];
    in-out property <string> export-quality: "balanced";
    in-out property <float> export-blend-width: 0.05;
    in-out property <float> export-start-secs: 0.0;
    in-out property <float> export-end-secs: 0.0;
    in-out property <float> clip-duration-secs: 0.0;
    in-out property <string> export-model-path: "";
    in-out property <string> export-tracking-mode: "field";
    in-out property <int> export-detection-interval: 3;
    in-out property <bool> export-autocam-enabled: false;
    in-out property <bool> export-replay-enabled: false;

    // Export progress (also used by the main status bar).
    in-out property <bool> export-in-progress: false;
    in-out property <float> export-progress: 0.0; // 0..1
    in-out property <int> export-frames-done: 0;
    in-out property <int> export-frames-total: 0;
    in-out property <string> export-status-text: "";

    // Compile-time AI capability summary. Seeded by Rust at startup
    // so the user can tell at-a-glance whether ball tracking will
    // actually work with their build (TensorRT, CUDA, CoreML, etc).
    in-out property <string> ai-status: "AI: unknown";
    in-out property <bool> ai-available: false;

    in-out property <string> version: "";
    in-out property <string> last-output-path: "";

    // Lens profile info. Populated after auto-calibration so the user
    // can see which lens the detector resolved to. Empty strings render
    // as "Unknown" via the Lens card below; `lens-info-available` flips
    // when there's anything worth showing.
    in-out property <string> lens-left-camera: "";
    in-out property <string> lens-left-lens: "";
    in-out property <string> lens-left-source: "";
    in-out property <string> lens-right-camera: "";
    in-out property <string> lens-right-lens: "";
    in-out property <string> lens-right-source: "";
    in-out property <int> lens-candidates-count: 0;
    in-out property <bool> lens-info-available: false;

    // Opt-in use of IMU-derived camera orientation as initial seeds
    // for the bundle-adjustment optimizer. Helpful on clips whose first
    // frame is pointed off-axis; harmful if the IMU is noisy. Default
    // off because the feature-matching seed is reliable on most footage.
    in-out property <bool> use-imu-seeds: false;
    in-out property <int> calibration-frames: 4;
    in-out property <float> cal-akaze-threshold: 0.0001;
    in-out property <float> cal-detect-y-min: 0.05;
    in-out property <float> cal-detect-y-max: 0.95;
    in-out property <float> cal-skip-end-secs: 0.0;

    // When true (default), pan/zoom is clamped to the coverage boundary
    // so the viewport never shows black margins. Users can disable it
    // to inspect what is happening beyond the stitched region, which is
    // useful for calibration debug.
    in-out property <bool> use-constrained-look: true;

    // Recent-files dialog state.
    in-out property <bool> recent-dialog-open: false;
    in-out property <[string]> recent-left-paths: [];
    in-out property <[string]> recent-right-paths: [];
    in-out property <[string]> recent-calibration-paths: [];

    // Keyboard shortcut help modal.
    in-out property <bool> shortcuts-dialog-open: false;

    // Preferences dialog state.
    in-out property <bool> prefs-dialog-open: false;
    in-out property <string> prefs-default-codec: "h264";
    in-out property <string> prefs-default-quality: "balanced";
    in-out property <float> prefs-default-blend-width: 0.05;
    in-out property <string> prefs-ai-model-path: "";

    // Toast notification list (Tier 3a).
    in-out property <[Toast]> toasts: [];
    callback toast-dismissed(int);

    // Telemetry panel state.
    in-out property <bool> stats-panel-open: false;
    in-out property <float> telem-fps-avg: 0.0;
    in-out property <float> telem-fps-recent: 0.0;
    in-out property <float> telem-decode-ms: 0.0;
    in-out property <float> telem-stitch-ms: 0.0;
    in-out property <float> telem-readback-ms: 0.0;
    in-out property <float> telem-encode-ms: 0.0;
    in-out property <float> telem-total-ms: 0.0;
    in-out property <float> telem-p99-ms: 0.0;
    in-out property <float> telem-detection-ms: 0.0;
    in-out property <int> telem-active-tracks: 0;
    in-out property <float> telem-ball-pct: 0.0;
    in-out property <float> telem-det-per-frame: 0.0;
    in-out property <int> telem-frames-dropped: 0;
    in-out property <string> telem-gpu-name: "";
    in-out property <string> telem-bottleneck: "";
    in-out property <float> telem-cal-confidence: 0.0;
    in-out property <float> telem-cal-reproj-err: 0.0;
    in-out property <int> telem-cal-matches: 0;

    // Per-camera lens intrinsics (populated by Rust after auto-calibrate
    // from `CalibrationResult.left_lens_profile` / `right_lens_profile`).
    // The Lens tab binds sliders to these properties; changes flow back
    // to Rust via `changed-lens-param`, which calls
    // `StitchRenderer::update_camera_params` for live preview.
    in-out property <float> lens-left-fx: 0.0;
    in-out property <float> lens-left-fy: 0.0;
    in-out property <float> lens-left-cx: 0.0;
    in-out property <float> lens-left-cy: 0.0;
    in-out property <float> lens-left-k1: 0.0;
    in-out property <float> lens-left-k2: 0.0;
    in-out property <float> lens-left-k3: 0.0;
    in-out property <float> lens-left-k4: 0.0;
    in-out property <float> lens-right-fx: 0.0;
    in-out property <float> lens-right-fy: 0.0;
    in-out property <float> lens-right-cx: 0.0;
    in-out property <float> lens-right-cy: 0.0;
    in-out property <float> lens-right-k1: 0.0;
    in-out property <float> lens-right-k2: 0.0;
    in-out property <float> lens-right-k3: 0.0;
    in-out property <float> lens-right-k4: 0.0;
    // Slider display ranges (set by Rust to baseline +/- safe delta).
    in-out property <float> lens-fx-min: 0.0;
    in-out property <float> lens-fx-max: 0.0;
    in-out property <float> lens-fy-min: 0.0;
    in-out property <float> lens-fy-max: 0.0;
    in-out property <float> lens-cx-min: 0.0;
    in-out property <float> lens-cx-max: 0.0;
    in-out property <float> lens-cy-min: 0.0;
    in-out property <float> lens-cy-max: 0.0;
    in-out property <float> lens-k-range: 0.3; // k sliders: baseline +/- this
    in-out property <bool> lens-dirty: false;
    // Which camera the lens-tab sliders are editing.
    in-out property <string> lens-selected-camera: "left";

    // ── Callbacks into Rust ──

    callback pick-left-video();
    callback pick-right-video();
    callback pick-calibration();
    callback auto-calibrate();
    callback toggle-playback();
    callback step-forward();
    callback step-backward();
    callback seek(float);
    // Relative seek in seconds (negative for rewind). CLI parity with `[` and `]`.
    callback seek-relative(float);
    // Mouse drag delta in pixels.
    callback pan(float, float);
    // Scroll wheel delta (degrees FOV per tick).
    callback zoom(float);
    // Reset yaw/pitch/fov to defaults.
    callback reset-view();
    // Settings-panel slider callbacks.
    callback changed-blend-width(float);
    callback changed-rig-tilt(float);
    callback changed-rig-roll(float);
    callback changed-sync-offset(int);
    callback changed-fov(float);
    // Live calibration editing.
    callback changed-cal-intersect(float);
    callback changed-cal-camera-axis-offset(float);
    callback changed-cal-x-ty(float);
    callback save-calibration();
    callback reset-calibration();
    // Live lens parameter editing. Fires on any of the 8 sliders per
    // camera; Rust reads the property values for the currently-selected
    // camera and calls update_camera_params.
    callback changed-lens-param();
    callback reset-lens();

    // Lens picker dialog.
    callback lens-search-changed(string);
    callback lens-pick(int, string);
    callback lens-pick-file();
    in-out property <bool> lens-picker-open: false;
    in-out property <string> lens-search-query: "";
    in-out property <[string]> lens-search-results: [];
    in-out property <string> lens-pick-side: "both";

    // Lens preview mode (single-camera flat view).
    in-out property <bool> lens-preview-active: false;
    in-out property <string> lens-preview-side: "left";
    in-out property <float> lens-correction-amount: 1.0;
    callback changed-lens-preview();
    callback changed-lens-correction(float);

    // Constrained-look checkbox. Fires when the user toggles it so Rust
    // can sync `AppState.use_constrained_look` with the UI property
    // (Slint's <=> binding updates the property but Rust needs a notify
    // to act on the new value).
    callback changed-constrained-look();
    // Recent-files modal: load a specific path into one of the three
    // file slots. Same effect as picking it from the native dialog.
    callback load-recent-left(string);
    callback load-recent-right(string);
    callback load-recent-calibration(string);
    callback clear-recent-files();
    // Preferences dialog: open prefills from user_settings, save
    // writes back (Rust handles persistence), pick-model opens a
    // file dialog for the AI model path.
    callback open-prefs-dialog();
    callback save-prefs();
    callback pick-prefs-model();
    callback open-website();
    callback open-forum();
    in-out property <bool> prefs-telemetry-enabled: false;
    in-out property <bool> prefs-dark-mode: true;
    // Export dialog actions.
    callback open-export-dialog();
    callback pick-export-output();
    callback pick-export-model();
    callback start-export();
    callback cancel-export();
    callback submit-bug-report(string, string, bool);
    in-out property <bool> bug-dialog-open: false;
    in-out property <string> bug-user-contact: "";
    callback show-in-folder(string);
    callback toggle-recording(string, string);
    callback pick-recording-folder();
    in-out property <bool> recording: false;
    in-out property <string> recording-quality: "balanced";
    in-out property <string> recording-codec: "h264";
    in-out property <string> recording-folder: "";

    // Preview aspect ratio mode: "auto" fills the available space
    // preserving the source aspect; ratio values constrain the
    // preview container to that shape.
    in-out property <string> preview-aspect: "auto";
    callback changed-preview-aspect(string);

    // File management: per-side segment lists and removal.
    in-out property <[string]> left-segments: [];
    in-out property <[string]> right-segments: [];
    callback remove-left-segment(int);
    callback remove-right-segment(int);
    callback clear-left();
    callback clear-right();
    callback clear-calibration();

    // Left panel (files) visibility.
    in-out property <bool> files-panel-open: false;
    // Panel widths (resizable via drag handles).
    in-out property <length> left-panel-width: 260px;
    in-out property <length> right-panel-width: 280px;

    // Keyboard handling. The FocusScope must *wrap* the content so
    // key events have somewhere to bubble up when a child (button,
    // slider, text input) is focused. `init` grabs focus on startup
    // so shortcuts work before the user clicks anything. The
    // `refocus` callback lets Rust re-assert focus after any action
    // that a widget would otherwise steal it with.
    forward-focus: key-scope;
    public function refocus() { key-scope.focus(); }

    key-scope := FocusScope {
        // FocusScope doesn't fill its Window parent by default; the
        // VerticalBox below would render at its preferred height and
        // overflow the bottom of the window, hiding the transport
        // controls and status bar. Explicit 100/100 fixes that.
        width: 100%;
        height: 100%;
        init => {
            self.focus();
            Palette.color-scheme = root.dark-mode ? ColorScheme.dark : ColorScheme.light;
        }
        key-pressed(event) => {
            // Space: play/pause
            if (event.text == " ") { root.toggle-playback(); return accept; }
            // Arrow keys: pan
            if (event.text == Key.LeftArrow)  { root.pan(-20, 0); return accept; }
            if (event.text == Key.RightArrow) { root.pan(20, 0);  return accept; }
            if (event.text == Key.UpArrow)    { root.pan(0, -20); return accept; }
            if (event.text == Key.DownArrow)  { root.pan(0, 20);  return accept; }
            // +/- : zoom
            if (event.text == "+" || event.text == "=") { root.zoom(-5); return accept; }
            if (event.text == "-" || event.text == "_") { root.zoom(5);  return accept; }
            // [ / ] : seek by 5s
            if (event.text == "[") { root.seek-relative(-5); return accept; }
            if (event.text == "]") { root.seek-relative(5);  return accept; }
            // R : reset view
            if (event.text == "r" || event.text == "R") { root.reset-view(); return accept; }
            // F or F11 : toggle fullscreen
            if (event.text == "f" || event.text == "F" || event.text == Key.F11) {
                root.full-screen = !root.full-screen;
                return accept;
            }
            return reject;
        }

        // VerticalLayout (not VerticalBox) because VerticalBox applies
        // implicit outer padding that pushed the bottom transport/status
        // bars off the content area. Explicit layout with zero spacing
        // ensures the file-bar + preview + transport + status fit the
        // window exactly, no inset on any edge.
        VerticalLayout {
            spacing: 0;

        // ── Toolbar ──
        Rectangle {
            background: root.bg-bar;
            height: 42px;

            HorizontalBox {
                padding: 6px;
                spacing: 6px;
                alignment: start;

                Button {
                    text: root.files-panel-open ? "◀ Files" : "Files ▶";
                    clicked => { root.files-panel-open = !root.files-panel-open; }
                }

                if root.calibrating: Text {
                    text: root.calibration-step;
                    color: #8888ff;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                Button { text: "?"; clicked => { root.shortcuts-dialog-open = true; } }
                Button { text: "⚙"; clicked => { root.open-prefs-dialog(); } }

                Button {
                    text: "Export…";
                    enabled: root.files-loaded && !root.export-in-progress;
                    primary: true;
                    clicked => { root.open-export-dialog(); }
                }

            }

            // Panel toggle pinned to the window's far right
            Rectangle {
                width: 36px;
                height: 42px;
                background: panel-toggle-touch.has-hover ? root.bg-hover : transparent;

                panel-toggle-touch := TouchArea {
                    enabled: root.files-loaded;
                    clicked => { root.controls-open = !root.controls-open; }
                    mouse-cursor: pointer;
                }

                Text {
                    text: root.controls-open ? "▶" : "◀";
                    color: root.files-loaded ? root.text-secondary : root.text-faint;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // ── Left files panel + Preview + Right controls ──
        HorizontalLayout {
            spacing: 0;
            vertical-stretch: 1;

            // ── Left files panel ──
            if root.files-panel-open: Rectangle {
                background: root.bg-panel;
                width: root.left-panel-width;

                // Resize handle on the right edge
                Rectangle {
                    x: parent.width - 4px;
                    width: 6px;
                    height: parent.height;
                    background: left-resize.has-hover || left-resize.pressed ? #555 : #333;

                    left-resize := TouchArea {
                        mouse-cursor: ew-resize;
                        moved => {
                            if (self.pressed) {
                                root.left-panel-width = max(180px, root.left-panel-width + (self.mouse-x - self.pressed-x));
                            }
                        }
                    }
                }

                ScrollView {
                    horizontal-scrollbar-policy: always-off;

                    VerticalLayout {
                        padding: 10px;
                        spacing: 8px;
                        alignment: start;

                        // Left video section
                        HorizontalLayout {
                            spacing: 6px;
                            Text { text: "Left"; color: #8ae68a; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-stretch: 1; }
                            Button { text: "+"; clicked => { root.pick-left-video(); } }
                            Button { text: "Clear"; enabled: root.left-path != ""; clicked => { root.clear-left(); } }
                        }

                        if root.left-segments.length == 0: Text {
                            text: "No video selected";
                            color: #666;
                            font-size: 11px;
                        }

                        for seg[idx] in root.left-segments: Rectangle {
                            height: 26px;
                            border-radius: 4px;
                            background: root.bg-card;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 4px;
                                spacing: 4px;
                                Text {
                                    text: (idx + 1) + ". " + seg;
                                    color: #ccc;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                Rectangle {
                                    width: 18px;
                                    height: 18px;
                                    border-radius: 3px;
                                    background: seg-rm.has-hover ? #3a2020 : transparent;
                                    Text { text: "×"; color: #888; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                    seg-rm := TouchArea { clicked => { root.remove-left-segment(idx); } }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: root.border-subtle; }

                        // Right video section
                        HorizontalLayout {
                            spacing: 6px;
                            Text { text: "Right"; color: #8ae68a; font-size: 12px; font-weight: 600; vertical-alignment: center; horizontal-stretch: 1; }
                            Button { text: "+"; clicked => { root.pick-right-video(); } }
                            Button { text: "Clear"; enabled: root.right-path != ""; clicked => { root.clear-right(); } }
                        }

                        if root.right-segments.length == 0: Text {
                            text: "No video selected";
                            color: #666;
                            font-size: 11px;
                        }

                        for seg[idx] in root.right-segments: Rectangle {
                            height: 26px;
                            border-radius: 4px;
                            background: root.bg-card;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 4px;
                                spacing: 4px;
                                Text {
                                    text: (idx + 1) + ". " + seg;
                                    color: #ccc;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                Rectangle {
                                    width: 18px;
                                    height: 18px;
                                    border-radius: 3px;
                                    background: seg-rm2.has-hover ? #3a2020 : transparent;
                                    Text { text: "×"; color: #888; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                    seg-rm2 := TouchArea { clicked => { root.remove-right-segment(idx); } }
                                }
                            }
                        }

                        if root.has-both-videos || root.calibration-path != "": Rectangle { height: 1px; background: root.border-subtle; }

                        if root.has-both-videos || root.calibration-path != "": Text { text: "Calibration"; color: #aaa; font-size: 12px; font-weight: 600; }

                        if root.has-both-videos: HorizontalLayout {
                            spacing: 4px;
                            Button {
                                text: root.calibrating
                                    ? "Calibrating..."
                                    : (root.files-loaded ? "Re-calibrate" : "Auto Calibrate");
                                enabled: !root.calibrating;
                                horizontal-stretch: 1;
                                clicked => { root.auto-calibrate(); }
                            }
                            Button {
                                text: "Load…";
                                clicked => { root.pick-calibration(); }
                            }
                        }

                        if root.has-both-videos: VerticalLayout {
                            spacing: 6px;

                            cal-advanced := SectionHeader {
                                title: "Advanced";
                                expanded: false;
                            }

                            if cal-advanced.expanded: VerticalLayout {
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 8px;
                                    Text { text: "Frames:"; color: #888; font-size: 11px; vertical-alignment: center; }
                                    ComboBox {
                                        model: ["2", "4", "6", "8"];
                                        current-value: root.calibration-frames;
                                        width: 56px;
                                        enabled: !root.calibrating;
                                        selected(v) => { root.calibration-frames = max(2, v.to-float()); }
                                    }

                                    CheckBox {
                                        text: "IMU seeds";
                                        checked <=> root.use-imu-seeds;
                                        enabled: !root.calibrating;
                                    }
                                }

                                LabeledSlider {
                                    label: "AKAZE threshold";
                                    minimum: 0.00005;
                                    maximum: 0.005;
                                    value <=> root.cal-akaze-threshold;
                                    decimals: 4;
                                    changed(v) => {}
                                }

                                LabeledSlider {
                                    label: "Detect Y min";
                                    minimum: 0;
                                    maximum: 0.5;
                                    value <=> root.cal-detect-y-min;
                                    decimals: 2;
                                    changed(v) => {}
                                }

                                LabeledSlider {
                                    label: "Detect Y max";
                                    minimum: 0.5;
                                    maximum: 1.0;
                                    value <=> root.cal-detect-y-max;
                                    decimals: 2;
                                    changed(v) => {}
                                }

                                LabeledSlider {
                                    label: "Skip end";
                                    minimum: 0;
                                    maximum: 60;
                                    value <=> root.cal-skip-end-secs;
                                    suffix: "s";
                                    decimals: 0;
                                    changed(v) => {}
                                }
                            }
                        }

                        if root.calibration-path != "": Rectangle {
                            height: 26px;
                            border-radius: 4px;
                            background: root.bg-card;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 4px;
                                spacing: 4px;
                                Text {
                                    text: root.calibration-path;
                                    color: #ccc;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                Rectangle {
                                    width: 18px;
                                    height: 18px;
                                    border-radius: 3px;
                                    background: cal-rm.has-hover ? #3a2020 : transparent;
                                    Text { text: "×"; color: #888; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                    cal-rm := TouchArea { clicked => { root.clear-calibration(); } }
                                }
                            }
                        }

                        // Stitching settings only appear after calibration is loaded
                        if root.files-loaded: Rectangle { height: 1px; background: root.border-subtle; }

                        if root.files-loaded: Text { text: "Stitching"; color: #aaa; font-size: 12px; font-weight: 600; }

                        if root.files-loaded: LabeledSlider {
                            label: "Seam blend";
                            minimum: 0;
                            maximum: 0.3;
                            value <=> root.blend-width;
                            decimals: 2;
                            changed(v) => { root.changed-blend-width(v); }
                        }

                        if root.files-loaded: LabeledSlider {
                            label: "Rig tilt";
                            minimum: -30;
                            maximum: 30;
                            value <=> root.rig-tilt;
                            suffix: "°";
                            decimals: 1;
                            changed(v) => { root.changed-rig-tilt(v); }
                        }

                        if root.files-loaded: LabeledSlider {
                            label: "Rig roll";
                            minimum: -15;
                            maximum: 15;
                            value <=> root.rig-roll;
                            suffix: "°";
                            decimals: 1;
                            changed(v) => { root.changed-rig-roll(v); }
                        }

                        if root.files-loaded: HorizontalLayout {
                            spacing: 4px;
                            alignment: stretch;
                            Text { text: "Sync offset"; color: #aaa; font-size: 11px; vertical-alignment: center; width: 80px; }
                            sync-input := LineEdit {
                                text: root.sync-offset;
                                horizontal-stretch: 1;
                                accepted => { root.sync-offset = self.text.to-float(); root.changed-sync-offset(self.text.to-float()); }
                            }
                            Text { text: "frames"; color: #777; font-size: 10px; vertical-alignment: center; }
                            Button { text: "Apply"; clicked => { root.sync-offset = sync-input.text.to-float(); root.changed-sync-offset(sync-input.text.to-float()); } }
                        }

                        if root.files-loaded && (root.cal-dirty || root.lens-dirty): Button {
                            text: "Save Calibration";
                            primary: true;
                            clicked => { root.save-calibration(); }
                        }

                        // Field ROI status
                        if root.files-loaded: Rectangle { height: 1px; background: root.border-subtle; }

                        if root.files-loaded: HorizontalLayout {
                            spacing: 6px;
                            Text {
                                text: root.has-roi ? "Field ROI: loaded" : "Field ROI: none";
                                color: root.has-roi ? #8ae68a : #777;
                                font-size: 11px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }

                        if root.files-loaded: HorizontalLayout {
                            spacing: 4px;
                            Button {
                                text: root.has-roi ? "Edit ROI..." : "Set ROI...";
                                horizontal-stretch: 1;
                                clicked => { root.launch-roi-editor(); }
                            }
                            Button {
                                text: "Paste ROI";
                                clicked => { root.paste-roi(); }
                            }
                        }

                        if root.files-loaded: LineEdit {
                            placeholder-text: "Or paste ROI JSON here...";
                            accepted(text) => {
                                root.roi-manual-json = text;
                                root.paste-roi();
                            }
                        }

                        if root.files-loaded && !root.has-roi: Text {
                            text: "Draw in browser, Copy ROI, then Paste or type JSON above.";
                            color: root.text-dim;
                            font-size: 10px;
                            wrap: word-wrap;
                        }

                        Rectangle { height: 1px; background: root.border-subtle; }

                        Button {
                            text: "Recent…";
                            enabled: root.recent-left-paths.length > 0
                                   || root.recent-right-paths.length > 0
                                   || root.recent-calibration-paths.length > 0;
                            clicked => { root.recent-dialog-open = true; }
                        }
                    }
                }
            }

            // Preview (with mouse drag + scroll handling).
            // The outer Rectangle fills the layout cell; the inner
            // `preview-box` optionally constrains itself to a chosen
            // aspect ratio and centers inside the outer area.
            Rectangle {
                background: root.bg-preview;
                horizontal-stretch: 1;

                if !root.files-loaded: VerticalLayout {
                    alignment: center;
                    spacing: 12px;

                    Text {
                        text: "Reco Video Stitcher";
                        color: #555;
                        font-size: 20px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "1. Open Files panel and add left + right videos\n2. Auto Calibrate or load a calibration JSON\n3. Preview, adjust, then Export";
                        color: #444;
                        font-size: 13px;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                    if root.status-text != "": Text {
                        text: root.status-text;
                        color: #666;
                        font-size: 12px;
                        horizontal-alignment: center;
                    }
                }

                // Aspect-constrained preview container. When "auto"
                // (default) it fills the parent; when a ratio is
                // chosen it shrinks one axis to maintain that ratio,
                // centered within the outer Rectangle.
                preview-box := Rectangle {
                    property <float> ratio:
                        root.preview-aspect == "16:9" ? (16.0 / 9.0)
                      : root.preview-aspect == "4:3"  ? (4.0 / 3.0)
                      : root.preview-aspect == "21:9" ? (21.0 / 9.0)
                      : 0;

                    property <length> fit-w:
                        ratio > 0 ? min(parent.width, parent.height * ratio / 1.0) : parent.width;
                    property <length> fit-h:
                        ratio > 0 ? min(parent.height, parent.width / ratio * 1.0) : parent.height;

                    width: fit-w;
                    height: fit-h;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;

                    if root.files-loaded: Image {
                        source: root.preview-frame;
                        image-fit: contain;
                        width: 100%;
                        height: 100%;
                    }

                    // ROI vertex overlay (visible in lens preview mode).
                    // Absolute-positioned dots at each polygon vertex.
                    for idx in root.roi-points-x.length: Rectangle {
                        visible: root.lens-preview-active && root.has-roi;
                        x: root.roi-points-x[idx] * preview-box.width - 4px;
                        y: root.roi-points-y[idx] * preview-box.height - 4px;
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: #0f08;
                        border-width: 1px;
                        border-color: #0f0;
                    }
                }

                drag := TouchArea {
                    enabled: root.files-loaded;
                    property <length> last-x: 0px;
                    property <length> last-y: 0px;

                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            self.last-x = self.mouse-x;
                            self.last-y = self.mouse-y;
                        }
                    }

                    moved => {
                        if (self.pressed) {
                            root.pan(
                                (self.mouse-x - self.last-x) / 1px,
                                (self.mouse-y - self.last-y) / 1px,
                            );
                            self.last-x = self.mouse-x;
                            self.last-y = self.mouse-y;
                        }
                    }

                    scroll-event(e) => {
                        root.zoom(-e.delta-y / 40px);
                        return accept;
                    }
                }
            }

            // Right-side controls panel. Collapsible sections keep
            // the default view compact; ScrollView catches overflow
            // when advanced sections are expanded on short screens.
            if root.controls-open: Rectangle {
                background: root.bg-panel;
                width: root.right-panel-width;

                // Resize handle on the left edge
                Rectangle {
                    x: 0;
                    width: 6px;
                    height: parent.height;
                    background: right-resize.has-hover || right-resize.pressed ? #555 : #333;

                    right-resize := TouchArea {
                        mouse-cursor: ew-resize;
                        moved => {
                            if (self.pressed) {
                                root.right-panel-width = max(200px, root.right-panel-width - (self.mouse-x - self.pressed-x));
                            }
                        }
                    }
                }

                ScrollView {
                    horizontal-scrollbar-policy: always-off;

                VerticalLayout {
                    padding: 12px;
                    spacing: 10px;
                    alignment: start;

                    // ── Camera (hidden during lens preview) ──
                    if !root.lens-preview-active: Text {
                        text: "Camera";
                        color: #fff;
                        font-size: 13px;
                        font-weight: 600;
                    }

                    if !root.lens-preview-active: LabeledSlider {
                        label: "Field of view";
                        minimum: 20;
                        maximum: 150;
                        value <=> root.fov;
                        suffix: "°";
                        decimals: 0;
                        changed(v) => { root.changed-fov(v); }
                    }

                    if !root.lens-preview-active: CheckBox {
                        text: "Constrained look";
                        checked <=> root.use-constrained-look;
                        toggled => { root.changed-constrained-look(); }
                    }

                    if !root.lens-preview-active: Button {
                        text: "Reset View";
                        clicked => { root.reset-view(); }
                    }

                    if !root.lens-preview-active: Rectangle { height: 1px; background: root.border-subtle; }

                    // ── Lens (collapsible: info always, sliders on demand) ──
                    lens-section := SectionHeader {
                        title: root.lens-info-available
                            ? "Lens - " + root.lens-left-camera
                            : "Lens";
                        expanded: false;
                    }

                    if lens-section.expanded && root.files-loaded: VerticalLayout {
                        spacing: 6px;

                        if root.lens-info-available: VerticalLayout {
                            spacing: 4px;
                            HorizontalLayout {
                                spacing: 4px;
                                Text { text: "L"; color: #8ae68a; font-size: 10px; font-weight: 600; vertical-alignment: center; width: 14px; }
                                Text { text: root.lens-left-source + " - " + root.lens-left-camera; color: #ccc; font-size: 10px; vertical-alignment: center; overflow: elide; horizontal-stretch: 1; }
                            }
                            HorizontalLayout {
                                spacing: 4px;
                                Text { text: "R"; color: #8ae68a; font-size: 10px; font-weight: 600; vertical-alignment: center; width: 14px; }
                                Text { text: root.lens-right-source + " - " + root.lens-right-camera; color: #ccc; font-size: 10px; vertical-alignment: center; overflow: elide; horizontal-stretch: 1; }
                            }
                        }

                        if !root.lens-info-available: Text {
                            text: "Auto-calibrate to detect lens.";
                            color: #777; font-size: 11px;
                        }

                        Button {
                            text: "Browse profiles...";
                            clicked => { root.lens-picker-open = true; }
                        }

                        Rectangle { height: 4px; }

                        CheckBox {
                            text: "Lens correction";
                            checked: root.lens-correction-amount > 0.5;
                            toggled => {
                                root.lens-correction-amount = self.checked ? 1.0 : 0.0;
                                root.changed-lens-correction(root.lens-correction-amount);
                            }
                        }

                        CheckBox {
                            text: "Lens preview (single camera)";
                            checked <=> root.lens-preview-active;
                            toggled => { root.changed-lens-preview(); }
                        }

                        if root.lens-preview-active: HorizontalLayout {
                            spacing: 4px;
                            Button { text: "Left"; primary: root.lens-preview-side == "left"; clicked => { root.lens-preview-side = "left"; root.changed-lens-preview(); } }
                            Button { text: "Right"; primary: root.lens-preview-side == "right"; clicked => { root.lens-preview-side = "right"; root.changed-lens-preview(); } }
                        }

                        // Fine-tune: auto-expands in lens preview mode
                        lens-tune := SectionHeader {
                            title: "Fine-tune";
                            expanded: root.lens-preview-active;
                        }

                        if lens-tune.expanded: VerticalLayout {
                            spacing: 4px;

                            HorizontalLayout {
                                spacing: 4px;
                                Button { text: "Left"; primary: root.lens-selected-camera == "left"; clicked => { root.lens-selected-camera = "left"; } }
                                Button { text: "Right"; primary: root.lens-selected-camera == "right"; clicked => { root.lens-selected-camera = "right"; } }
                                Button { text: "Both"; primary: root.lens-selected-camera == "both"; clicked => { root.lens-selected-camera = "both"; } }
                            }

                            if root.lens-selected-camera == "left" || root.lens-selected-camera == "both": VerticalLayout {
                                spacing: 3px;
                                LabeledSlider { label: "fx"; minimum: root.lens-fx-min; maximum: root.lens-fx-max; value <=> root.lens-left-fx; decimals: 0; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "fy"; minimum: root.lens-fy-min; maximum: root.lens-fy-max; value <=> root.lens-left-fy; decimals: 0; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "cx"; minimum: root.lens-cx-min; maximum: root.lens-cx-max; value <=> root.lens-left-cx; decimals: 0; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "cy"; minimum: root.lens-cy-min; maximum: root.lens-cy-max; value <=> root.lens-left-cy; decimals: 0; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "k1"; minimum: -root.lens-k-range; maximum: root.lens-k-range; value <=> root.lens-left-k1; decimals: 2; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "k2"; minimum: -root.lens-k-range; maximum: root.lens-k-range; value <=> root.lens-left-k2; decimals: 2; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "k3"; minimum: -root.lens-k-range; maximum: root.lens-k-range; value <=> root.lens-left-k3; decimals: 2; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "k4"; minimum: -root.lens-k-range; maximum: root.lens-k-range; value <=> root.lens-left-k4; decimals: 2; changed(v) => { root.changed-lens-param(); } }
                            }

                            if root.lens-selected-camera == "right": VerticalLayout {
                                spacing: 3px;
                                LabeledSlider { label: "fx"; minimum: root.lens-fx-min; maximum: root.lens-fx-max; value <=> root.lens-right-fx; decimals: 0; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "fy"; minimum: root.lens-fy-min; maximum: root.lens-fy-max; value <=> root.lens-right-fy; decimals: 0; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "cx"; minimum: root.lens-cx-min; maximum: root.lens-cx-max; value <=> root.lens-right-cx; decimals: 0; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "cy"; minimum: root.lens-cy-min; maximum: root.lens-cy-max; value <=> root.lens-right-cy; decimals: 0; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "k1"; minimum: -root.lens-k-range; maximum: root.lens-k-range; value <=> root.lens-right-k1; decimals: 2; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "k2"; minimum: -root.lens-k-range; maximum: root.lens-k-range; value <=> root.lens-right-k2; decimals: 2; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "k3"; minimum: -root.lens-k-range; maximum: root.lens-k-range; value <=> root.lens-right-k3; decimals: 2; changed(v) => { root.changed-lens-param(); } }
                                LabeledSlider { label: "k4"; minimum: -root.lens-k-range; maximum: root.lens-k-range; value <=> root.lens-right-k4; decimals: 2; changed(v) => { root.changed-lens-param(); } }
                            }

                            Button { text: "Reset Lens"; enabled: root.lens-dirty; clicked => { root.reset-lens(); } }
                        }
                    }

                    if !lens-section.expanded: Rectangle { height: 1px; background: #2a2a2a; }

                    // ── Calibration (collapsible) ──
                    cal-section := SectionHeader {
                        title: "Calibration";
                        expanded: false;
                    }

                    if cal-section.expanded: VerticalLayout {
                        spacing: 8px;

                        LabeledSlider {
                            label: "Intersect";
                            minimum: -1.0;
                            maximum: 1.0;
                            value <=> root.cal-intersect;
                            decimals: 3;
                            changed(v) => { root.changed-cal-intersect(v); }
                        }

                        LabeledSlider {
                            label: "Camera axis offset";
                            minimum: -0.6;
                            maximum: 0.6;
                            value <=> root.cal-camera-axis-offset;
                            decimals: 3;
                            changed(v) => { root.changed-cal-camera-axis-offset(v); }
                        }

                        LabeledSlider {
                            label: "x_ty";
                            minimum: -0.1;
                            maximum: 0.1;
                            value <=> root.cal-x-ty;
                            decimals: 3;
                            changed(v) => { root.changed-cal-x-ty(v); }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            Button {
                                text: "Save Cal & Lens";
                                enabled: root.cal-dirty;
                                clicked => { root.save-calibration(); }
                            }
                            Button {
                                text: "Reset";
                                enabled: root.cal-dirty;
                                clicked => { root.reset-calibration(); }
                            }
                        }
                    }

                    if !cal-section.expanded: Rectangle { height: 1px; background: #2a2a2a; }

                    // ── Stats (collapsible, hidden in lens preview) ──
                    if !root.lens-preview-active: VerticalLayout {
                        spacing: 10px;

                    stats-section := SectionHeader {
                        title: "Stats";
                        expanded: false;
                    }

                    if stats-section.expanded: VerticalLayout {
                        spacing: 4px;

                        Text { text: "FPS: " + round(root.telem-fps-avg) + " avg / " + round(root.telem-fps-recent) + " recent"; color: #aaa; font-size: 11px; }
                        Text { text: "Frame: " + round(root.telem-total-ms * 10) / 10 + " / " + round(root.telem-p99-ms * 10) / 10 + " p99 ms"; color: #aaa; font-size: 11px; }
                        Text { text: "  Decode:   " + round(root.telem-decode-ms * 10) / 10 + " ms"; color: #888; font-size: 10px; }
                        Text { text: "  Stitch:   " + round(root.telem-stitch-ms * 10) / 10 + " ms"; color: #888; font-size: 10px; }
                        Text { text: "  Readback: " + round(root.telem-readback-ms * 10) / 10 + " ms"; color: #888; font-size: 10px; }
                        Text { text: "  Encode:   " + round(root.telem-encode-ms * 10) / 10 + " ms"; color: #888; font-size: 10px; }
                        if root.telem-bottleneck != "": Text { text: "Bottleneck: " + root.telem-bottleneck; color: #e8a060; font-size: 11px; font-weight: 600; }
                        if root.telem-gpu-name != "": Text { text: root.telem-gpu-name; color: #666; font-size: 10px; }
                        if root.telem-frames-dropped > 0: Text { text: "Dropped: " + root.telem-frames-dropped; color: #f88; font-size: 11px; }

                        Rectangle { height: 4px; }
                        Text { text: "Ball: " + round(root.telem-ball-pct) + "%  Tracks: " + root.telem-active-tracks + "  Det: " + round(root.telem-det-per-frame * 10) / 10 + "/f"; color: #aaa; font-size: 10px; }
                        if root.telem-detection-ms > 0: Text { text: "Detection: " + round(root.telem-detection-ms * 10) / 10 + " ms"; color: #aaa; font-size: 10px; }

                        if root.telem-cal-matches > 0: Rectangle { height: 4px; }
                        if root.telem-cal-matches > 0: Text { text: "Cal: " + round(root.telem-cal-confidence * 100) + "% conf, " + root.telem-cal-matches + " matches, reproj " + round(root.telem-cal-reproj-err * 10000) / 10000; color: #aaa; font-size: 10px; }
                    }
                    }  // close stats wrapper (lens-preview gate)
                }
                }  // close ScrollView
            }

        }

        // ── Transport bar (single inline row) ──
        Rectangle {
            background: root.bg-bar;
            height: 44px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 4px;
                padding-bottom: 4px;
                spacing: 6px;

                // Playback buttons
                Button { text: "|<"; enabled: root.files-loaded; clicked => { root.step-backward(); } }
                Button { text: root.playing ? "||" : "▶"; enabled: root.files-loaded; clicked => { root.toggle-playback(); } }
                Button { text: ">|"; enabled: root.files-loaded; clicked => { root.step-forward(); } }

                Text {
                    text: root.current-time-text;
                    color: #aaa;
                    font-size: 11px;
                    vertical-alignment: center;
                    width: 44px;
                    horizontal-alignment: right;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    height: 24px;

                    // Export range indicator (green tint behind the slider)
                    if root.export-start-secs > 0 || root.export-end-secs < root.clip-duration-secs: Rectangle {
                        property <float> start-frac: root.clip-duration-secs > 0
                            ? root.export-start-secs / root.clip-duration-secs : 0;
                        property <float> end-frac: root.clip-duration-secs > 0
                            ? root.export-end-secs / root.clip-duration-secs : 1.0;

                        x: parent.width * start-frac;
                        width: parent.width * (end-frac - start-frac);
                        height: parent.height;
                        background: #4a7a4a33;
                        border-radius: 2px;
                    }

                    Slider {
                        width: 100%;
                        minimum: 0;
                        maximum: root.total-frames == 0 ? 1.0 : 1.0 * root.total-frames;
                        value: 1.0 * root.current-frame;
                        enabled: root.files-loaded;
                        released(val) => {
                            if root.total-frames > 0 { root.seek(val / root.total-frames); }
                        }
                    }
                }

                Text {
                    text: root.total-time-text;
                    color: #666;
                    font-size: 11px;
                    vertical-alignment: center;
                    width: 44px;
                }

                // Record button
                Rectangle {
                    width: rec-layout.preferred-width + 12px;
                    height: 28px;
                    border-radius: 5px;
                    background: root.recording ? #4a1010 : rec-touch.has-hover ? #3a2020 : #2a1a1a;
                    border-width: 1px;
                    border-color: root.recording ? #e04040 : #553333;
                    rec-touch := TouchArea {
                        enabled: root.files-loaded && !root.export-in-progress;
                        clicked => { root.toggle-recording(root.recording-codec, root.recording-quality); }
                    }
                    rec-layout := HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 5px;
                        Rectangle { width: 7px; height: 7px; y: (parent.height - self.height) / 2; border-radius: 4px; background: root.recording ? #ff3030 : #883030; }
                        Text { text: root.recording ? "Stop" : "Rec*"; color: root.recording ? #ff6060 : #cc8888; font-size: 11px; font-weight: 600; vertical-alignment: center; }
                    }
                }

                if !root.recording: ComboBox {
                    model: ["fast", "balanced", "high"];
                    current-value <=> root.recording-quality;
                    enabled: root.files-loaded && !root.export-in-progress;
                    width: 82px;
                }

                ComboBox {
                    model: ["auto", "16:9", "4:3", "21:9"];
                    current-value <=> root.preview-aspect;
                    enabled: root.files-loaded;
                    width: 78px;
                    selected(v) => { root.changed-preview-aspect(v); }
                }
            }
        }

        // ── Status bar (or export progress when active) ──
        Rectangle {
            background: root.bg-bar;
            min-height: 28px;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;

                if !root.export-in-progress: Text {
                    text: root.status-text;
                    color: #666;
                    font-size: 11px;
                    vertical-alignment: center;
                }

                if root.export-in-progress: Text {
                    text: "Exporting: " + root.export-status-text;
                    color: #8f8;
                    font-size: 11px;
                    vertical-alignment: center;
                    font-weight: 600;
                }

                if root.export-in-progress: ProgressIndicator {
                    progress: root.export-progress;
                    min-width: 120px;
                    horizontal-stretch: 1;
                }

                if root.export-in-progress: Button {
                    text: "Cancel";
                    clicked => { root.cancel-export(); }
                }

                if !root.export-in-progress && root.last-output-path != "": Button {
                    text: "Show in folder";
                    clicked => { root.show-in-folder(root.last-output-path); }
                }

                if !root.export-in-progress: Rectangle { horizontal-stretch: 1; }

                if !root.export-in-progress && root.telem-fps-avg > 0: Text {
                    text: round(root.telem-fps-avg) + " / " + round(root.telem-fps-recent) + " fps";
                    color: #555;
                    font-size: 11px;
                    vertical-alignment: center;
                }

                if root.version != "": Text {
                    text: root.version;
                    color: #444;
                    font-size: 10px;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: bug-btn-layout.preferred-width + 10px;
                    height: 20px;
                    border-radius: 3px;
                    background: bug-touch.has-hover ? #333 : transparent;
                    bug-btn-layout := HorizontalLayout {
                        padding-left: 5px;
                        padding-right: 5px;
                        spacing: 4px;
                        Text { text: "Report Bug"; color: #666; font-size: 10px; vertical-alignment: center; }
                    }
                    bug-touch := TouchArea {
                        clicked => { root.bug-dialog-open = true; }
                    }
                }
            }
        }
        }  // close VerticalBox

        // ── Recent files dialog (modal) ──
        // Three columns (Left / Right / Calibration). Each entry is a
        // clickable row; click loads that path into the corresponding
        // file slot. Rendered as a sibling of the main layout so it
        // overlays everything.
        if root.recent-dialog-open: Rectangle {
            background: root.bg-scrim;
            TouchArea {
                clicked => { root.recent-dialog-open = false; }
            }

            Rectangle {
                width: 720px;
                height: 460px;
                background: root.bg-surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: root.border-mid;
                // Block click-through so clicks inside the panel do
                // not close the dialog.
                TouchArea {}

                VerticalLayout {
                    padding: 20px;
                    spacing: 12px;

                    HorizontalLayout {
                        alignment: space-between;
                        Text {
                            text: "Recent files";
                            color: #fff;
                            font-size: 16px;
                            font-weight: 600;
                        }
                        Button {
                            text: "Clear all";
                            clicked => {
                                root.clear-recent-files();
                                root.recent-dialog-open = false;
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        padding: 0;
                        vertical-stretch: 1;

                        // Three column wrappers share the same structure
                        // so the styling stays consistent.
                        Rectangle {
                            border-radius: 6px;
                            background: root.bg-panel;
                            horizontal-stretch: 1;
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                Text {
                                    text: "Left videos";
                                    color: #aaa;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                                ScrollView {
                                    VerticalLayout {
                                        spacing: 2px;
                                        for entry in root.recent-left-paths: Rectangle {
                                            height: 28px;
                                            border-radius: 4px;
                                            background: row-l.has-hover ? #2d2d2d : transparent;
                                            Text {
                                                text: entry;
                                                color: #ccc;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                                overflow: elide;
                                                x: 6px;
                                                width: parent.width - 12px;
                                            }
                                            row-l := TouchArea {
                                                clicked => {
                                                    root.load-recent-left(entry);
                                                    root.recent-dialog-open = false;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            border-radius: 6px;
                            background: root.bg-panel;
                            horizontal-stretch: 1;
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                Text {
                                    text: "Right videos";
                                    color: #aaa;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                                ScrollView {
                                    VerticalLayout {
                                        spacing: 2px;
                                        for entry in root.recent-right-paths: Rectangle {
                                            height: 28px;
                                            border-radius: 4px;
                                            background: row-r.has-hover ? #2d2d2d : transparent;
                                            Text {
                                                text: entry;
                                                color: #ccc;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                                overflow: elide;
                                                x: 6px;
                                                width: parent.width - 12px;
                                            }
                                            row-r := TouchArea {
                                                clicked => {
                                                    root.load-recent-right(entry);
                                                    root.recent-dialog-open = false;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            border-radius: 6px;
                            background: root.bg-panel;
                            horizontal-stretch: 1;
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                Text {
                                    text: "Calibrations";
                                    color: #aaa;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                                ScrollView {
                                    VerticalLayout {
                                        spacing: 2px;
                                        for entry in root.recent-calibration-paths: Rectangle {
                                            height: 28px;
                                            border-radius: 4px;
                                            background: row-c.has-hover ? #2d2d2d : transparent;
                                            Text {
                                                text: entry;
                                                color: #ccc;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                                overflow: elide;
                                                x: 6px;
                                                width: parent.width - 12px;
                                            }
                                            row-c := TouchArea {
                                                clicked => {
                                                    root.load-recent-calibration(entry);
                                                    root.recent-dialog-open = false;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: end;
                        Button {
                            text: "Close";
                            clicked => { root.recent-dialog-open = false; }
                        }
                    }
                }
            }
        }

        // ── Keyboard shortcuts dialog (modal) ──
        if root.shortcuts-dialog-open: Rectangle {
            background: root.bg-scrim;
            TouchArea {
                clicked => { root.shortcuts-dialog-open = false; }
            }

            Rectangle {
                width: 420px;
                height: 360px;
                background: root.bg-surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: root.border-mid;
                TouchArea {}

                VerticalLayout {
                    padding: 20px;
                    spacing: 8px;

                    Text {
                        text: "Keyboard shortcuts";
                        color: root.text-heading;
                        font-size: 16px;
                        font-weight: 600;
                    }

                    Rectangle { height: 1px; background: root.border-subtle; }

                    // Explicit two-column rows for alignment: the key
                    // column is fixed width, the description fills.
                    for row in [
                        { k: "Space", v: "Play / pause" },
                        { k: "Arrows", v: "Pan camera (hold) or step 1 frame (with playback paused)" },
                        { k: "+  /  -", v: "Zoom in / out" },
                        { k: "Scroll", v: "Zoom in / out" },
                        { k: "Drag", v: "Pan preview with mouse" },
                        { k: "[  /  ]", v: "Seek backward / forward 5 seconds" },
                        { k: "R", v: "Reset camera view (yaw, pitch, FOV)" },
                    ]: HorizontalLayout {
                        spacing: 12px;
                        Text {
                            text: row.k;
                            color: #a0e8a0;
                            font-size: 12px;
                            font-weight: 600;
                            width: 80px;
                        }
                        Text {
                            text: row.v;
                            color: #ccc;
                            font-size: 12px;
                            wrap: word-wrap;
                            horizontal-stretch: 1;
                        }
                    }

                    Rectangle { vertical-stretch: 1; }

                    Rectangle { height: 1px; background: root.border-subtle; }

                    HorizontalLayout {
                        spacing: 8px;
                        Button { text: "Website"; clicked => { root.open-website(); } }
                        Button { text: "Forum"; clicked => { root.open-forum(); } }
                        Rectangle { horizontal-stretch: 1; }
                        Button {
                            text: "Close";
                            clicked => { root.shortcuts-dialog-open = false; }
                        }
                    }
                }
            }
        }

        // ── Preferences dialog (modal) ──
        //
        // Editable subset of GuiSettings: default export codec,
        // default quality, default blend width, AI model path. Save
        // persists; Cancel discards.
        if root.prefs-dialog-open: Rectangle {
            background: root.bg-scrim;
            TouchArea {
                clicked => { root.prefs-dialog-open = false; }
            }

            Rectangle {
                width: 480px;
                height: min(parent.height - 60px, 680px);
                background: root.bg-surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: root.border-mid;
                TouchArea {}

                ScrollView {
                    horizontal-scrollbar-policy: always-off;

                VerticalLayout {
                    padding: 20px;
                    spacing: 12px;

                    Text {
                        text: "Preferences";
                        color: root.text-heading;
                        font-size: 16px;
                        font-weight: 600;
                    }

                    Rectangle { height: 1px; background: root.border-subtle; }

                    Text { text: "Default codec"; color: #ccc; font-size: 12px; }
                    ComboBox {
                        model: root.available-codecs;
                        current-value <=> root.prefs-default-codec;
                    }

                    Text { text: "Default quality"; color: #ccc; font-size: 12px; }
                    ComboBox {
                        model: ["fast", "balanced", "high"];
                        current-value <=> root.prefs-default-quality;
                    }

                    Text {
                        text: "Default seam blend (" + round(root.prefs-default-blend-width * 100) / 100 + ")";
                        color: #ccc;
                        font-size: 12px;
                    }
                    Slider {
                        minimum: 0;
                        maximum: 0.3;
                        value <=> root.prefs-default-blend-width;
                    }

                    Text { text: "AI model (ONNX)"; color: #ccc; font-size: 12px; }
                    HorizontalLayout {
                        spacing: 6px;
                        LineEdit {
                            text <=> root.prefs-ai-model-path;
                            placeholder-text: "Path to .onnx, or leave empty";
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "Browse…";
                            clicked => { root.pick-prefs-model(); }
                        }
                    }

                    Rectangle { height: 1px; background: root.border-subtle; }

                    Text { text: "Recording defaults"; color: #ccc; font-size: 12px; font-weight: 600; }

                    HorizontalLayout {
                        spacing: 10px;
                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "Codec"; color: #ccc; font-size: 12px; }
                            ComboBox {
                                model: root.available-codecs;
                                current-value <=> root.recording-codec;
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "Quality"; color: #ccc; font-size: 12px; }
                            ComboBox {
                                model: ["fast", "balanced", "high"];
                                current-value <=> root.recording-quality;
                            }
                        }
                    }

                    Text { text: "Recording folder"; color: #ccc; font-size: 12px; }
                    HorizontalLayout {
                        spacing: 6px;
                        LineEdit {
                            text <=> root.recording-folder;
                            placeholder-text: "Same as source video (default)";
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "Browse…";
                            clicked => { root.pick-recording-folder(); }
                        }
                    }

                    Rectangle { height: 1px; background: root.border-subtle; }

                    Text { text: "Appearance"; color: root.text-body; font-size: 12px; font-weight: 600; }

                    CheckBox {
                        text: "Dark mode";
                        checked <=> root.prefs-dark-mode;
                    }

                    Rectangle { height: 1px; background: root.border-subtle; }

                    Text { text: "Privacy"; color: root.text-body; font-size: 12px; font-weight: 600; }

                    CheckBox {
                        text: "Send anonymous usage data (opt-in)";
                        checked <=> root.prefs-telemetry-enabled;
                    }
                    Text {
                        text: "Helps improve Reco. Shares system info and performance data.";
                        color: #666;
                        font-size: 10px;
                        wrap: word-wrap;
                    }

                    Rectangle { height: 1px; background: root.border-subtle; }

                    Rectangle { vertical-stretch: 1; }

                    HorizontalLayout {
                        alignment: end;
                        spacing: 8px;
                        Button {
                            text: "Cancel";
                            clicked => { root.prefs-dialog-open = false; }
                        }
                        Button {
                            text: "Save";
                            primary: true;
                            clicked => {
                                root.save-prefs();
                                root.prefs-dialog-open = false;
                            }
                        }
                    }
                }
                }  // close ScrollView
            }
        }

        // ── Bug report dialog ──
        if root.bug-dialog-open: Rectangle {
            background: root.bg-scrim;
            TouchArea { clicked => { root.bug-dialog-open = false; } }

            Rectangle {
                width: 500px;
                height: min(parent.height - 60px, 420px);
                background: root.bg-surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: root.border-mid;
                TouchArea {}

                VerticalLayout {
                    padding: 24px;
                    spacing: 14px;

                    Text { text: "Report a Bug"; color: root.text-heading; font-size: 18px; font-weight: 600; }

                    Text {
                        text: "Tell us what happened. Your system info (GPU, OS, settings) will be included to help us fix the issue faster.";
                        color: root.text-muted;
                        font-size: 12px;
                        wrap: word-wrap;
                    }

                    Text { text: "What went wrong?"; color: root.text-body; font-size: 12px; }
                    bug-msg := LineEdit {
                        placeholder-text: "e.g. The video freezes when I click Export";
                    }

                    Text { text: "How can we reach you? (optional)"; color: root.text-body; font-size: 12px; }
                    bug-contact := LineEdit {
                        text <=> root.bug-user-contact;
                        placeholder-text: "Forum username or email";
                    }

                    bug-share-logs := CheckBox {
                        text: "Include system info and logs";
                        checked: true;
                    }
                    Text {
                        text: "Shares GPU model, OS, performance stats, and logs. No video content is sent.";
                        color: root.text-dim;
                        font-size: 10px;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: end;
                        Button { text: "Cancel"; clicked => { root.bug-dialog-open = false; } }
                        Button {
                            text: "Send Report";
                            primary: true;
                            enabled: bug-msg.text != "";
                            clicked => {
                                root.submit-bug-report(bug-msg.text, bug-contact.text, bug-share-logs.checked);
                                root.bug-dialog-open = false;
                            }
                        }
                    }
                }
            }
        }

        // ── Toast stack (floating overlay, bottom-right) ──
        // Rendered LAST so it sits on top of all modals. Does not
        // block input outside the cards because ToastStack has no
        // TouchArea - only the dismiss × inside each card.
        ToastStack {
            toasts: root.toasts;
            right-inset: root.controls-open ? root.right-panel-width : 0px;
            dismissed(id) => { root.toast-dismissed(id); }
        }

        // ── Export dialog (modal overlay) ──
        //
        // Placed as a sibling of the main VerticalBox so it renders on
        // top. Visibility toggled by `export-dialog-open`. Clicks on
        // the dark backdrop outside the panel dismiss the dialog.
        if root.export-dialog-open: Rectangle {
            background: root.bg-scrim; // 67% opacity scrim
            TouchArea {
                // Swallow clicks on the backdrop; clicking a transparent
                // area (not the panel) closes the dialog.
                clicked => { root.export-dialog-open = false; }
            }

            Rectangle {
                width: 560px;
                height: min(parent.height - 60px, 720px);
                background: root.bg-surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: root.border-mid;

                TouchArea {}

                ScrollView {
                    horizontal-scrollbar-policy: always-off;

                VerticalBox {
                    padding: 24px;
                    spacing: 14px;

                    Text {
                        text: "Export Stitched Video";
                        color: #fff;
                        font-size: 18px;
                        font-weight: 600;
                    }

                    Text {
                        text: "Run the full pipeline (decode → stitch → encode) and save the output.";
                        color: #999;
                        font-size: 12px;
                        wrap: word-wrap;
                    }

                    // Output path
                    Text { text: "Output file"; color: #ccc; font-size: 12px; }
                    HorizontalBox {
                        spacing: 6px;
                        padding: 0;
                        // Editable: users want to rename the suggested
                        // file without invoking the file dialog every
                        // time. Rust reads `export-output-path` verbatim
                        // when Start Export fires, so whatever is typed
                        // here is what gets written.
                        LineEdit {
                            text <=> root.export-output-path;
                            placeholder-text: "Pick a destination file, or type a path…";
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "Save to…";
                            clicked => { root.pick-export-output(); }
                        }
                    }

                    // Resolution presets
                    HorizontalBox {
                        spacing: 10px;
                        padding: 0;

                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "Resolution"; color: #ccc; font-size: 12px; }
                            ComboBox {
                                model: ["1080p (1920x1080)", "720p (1280x720)", "2K (2560x1440)", "4K (3840x2160)"];
                                current-index: root.export-width == 1280 ? 1
                                             : root.export-width == 2560 ? 2
                                             : root.export-width == 3840 ? 3
                                             : 0;
                                selected(v) => {
                                    if (v == "720p (1280x720)") {
                                        root.export-width = 1280;
                                        root.export-height = 720;
                                    } else if (v == "2K (2560x1440)") {
                                        root.export-width = 2560;
                                        root.export-height = 1440;
                                    } else if (v == "4K (3840x2160)") {
                                        root.export-width = 3840;
                                        root.export-height = 2160;
                                    } else {
                                        root.export-width = 1920;
                                        root.export-height = 1080;
                                    }
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            Text { text: root.export-width + " x " + root.export-height; color: #888; font-size: 11px; }
                        }
                    }

                    HorizontalBox {
                        spacing: 10px;
                        padding: 0;

                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "Codec"; color: #ccc; font-size: 12px; }
                            ComboBox {
                                model: root.available-codecs;
                                current-index: root.export-codec == "hevc" ? 1
                                             : root.export-codec == "av1" ? 2
                                             : 0;
                                selected(v) => { root.export-codec = v; }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "Quality"; color: #ccc; font-size: 12px; }
                            ComboBox {
                                model: ["fast", "balanced", "high"];
                                current-index: root.export-quality == "fast" ? 0
                                             : root.export-quality == "high" ? 2
                                             : 1;
                                selected(v) => { root.export-quality = v; }
                            }
                        }
                    }

                    // Processing range (start/end with sliders and manual input)
                    Text { text: "Processing range"; color: #ccc; font-size: 12px; }

                    HorizontalBox {
                        spacing: 8px;
                        padding: 0;

                        VerticalLayout {
                            spacing: 3px;
                            horizontal-stretch: 1;
                            Text { text: "Start (s)"; color: #888; font-size: 11px; }
                            Slider {
                                minimum: 0;
                                maximum: max(1, root.clip-duration-secs);
                                value <=> root.export-start-secs;
                                enabled: root.clip-duration-secs > 0;
                                changed(v) => {
                                    if v > root.export-end-secs { root.export-start-secs = root.export-end-secs; }
                                }
                            }
                            LineEdit {
                                text: root.export-start-secs == 0 ? "" : root.export-start-secs;
                                placeholder-text: "0:00";
                                edited(v) => {
                                    root.export-start-secs = Math.min(max(0, v.to-float()), root.export-end-secs);
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 3px;
                            horizontal-stretch: 1;
                            Text { text: "End (s)"; color: #888; font-size: 11px; }
                            Slider {
                                minimum: 0;
                                maximum: max(1, root.clip-duration-secs);
                                value <=> root.export-end-secs;
                                enabled: root.clip-duration-secs > 0;
                                changed(v) => {
                                    if v < root.export-start-secs { root.export-end-secs = root.export-start-secs; }
                                }
                            }
                            LineEdit {
                                text: root.export-end-secs;
                                placeholder-text: "";
                                edited(v) => {
                                    root.export-end-secs = Math.max(Math.min(v.to-float(), root.clip-duration-secs), root.export-start-secs);
                                }
                            }
                        }
                    }

                    Text {
                        property <float> range-dur: root.export-end-secs - root.export-start-secs;
                        text: range-dur <= 0
                            ? "Duration: 0s (nothing to export)"
                            : "Duration: " + round(range-dur * 10) / 10 + "s";
                        color: range-dur <= 0 ? #ff6666 : #888;
                        font-size: 11px;
                    }

                    CheckBox {
                        text: "Record replay (stacked raw input for re-stitching)";
                        checked <=> root.export-replay-enabled;
                    }

                    Rectangle { height: 1px; background: root.border-subtle; }

                    // AI Tracking section
                    HorizontalBox {
                        padding: 0;
                        spacing: 8px;
                        Text {
                            text: "AI Tracking";
                            color: #fff;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        CheckBox {
                            text: "Enable";
                            checked <=> root.export-autocam-enabled;
                            enabled: root.ai-available;
                        }
                    }

                    Text {
                        text: root.ai-status;
                        color: root.ai-available ? #8f8 : #f88;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    if root.export-autocam-enabled: VerticalLayout {
                        spacing: 8px;

                        HorizontalBox {
                            spacing: 6px;
                            padding: 0;
                            LineEdit {
                                text: root.export-model-path;
                                placeholder-text: "Pick a YOLO ONNX model…";
                                read-only: true;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: "Model…";
                                clicked => { root.pick-export-model(); }
                            }
                        }

                        HorizontalBox {
                            spacing: 10px;
                            padding: 0;

                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text { text: "Tracking mode"; color: #ccc; font-size: 12px; }
                                ComboBox {
                                    model: ["ball", "field", "sweep"];
                                    current-index: root.export-tracking-mode == "field" ? 1
                                                 : root.export-tracking-mode == "sweep" ? 2
                                                 : 0;
                                    selected(v) => { root.export-tracking-mode = v; }
                                }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text { text: "Detect every N frames"; color: #ccc; font-size: 12px; }
                                ComboBox {
                                    model: ["1", "3", "5", "10", "15", "30"];
                                    current-index: root.export-detection-interval == 1 ? 0
                                                 : root.export-detection-interval == 5 ? 2
                                                 : root.export-detection-interval == 10 ? 3
                                                 : root.export-detection-interval == 15 ? 4
                                                 : root.export-detection-interval == 30 ? 5
                                                 : 1;
                                    selected(v) => {
                                        root.export-detection-interval =
                                            v == "1" ? 1 : v == "5" ? 5 : v == "10" ? 10
                                            : v == "15" ? 15 : v == "30" ? 30 : 3;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle { height: 10px; }

                    HorizontalBox {
                        spacing: 10px;
                        padding: 0;

                        Rectangle { horizontal-stretch: 1; }

                        Button {
                            text: "Cancel";
                            clicked => { root.export-dialog-open = false; }
                        }

                        Button {
                            text: "Start Export";
                            primary: true;
                            enabled: root.export-output-path != "";
                            clicked => { root.start-export(); }
                        }
                    }
                }
                }  // close ScrollView
            }
        }
        // ── Lens profile picker dialog (modal) ──
        if root.lens-picker-open: Rectangle {
            background: root.bg-scrim;
            TouchArea { clicked => { root.lens-picker-open = false; } }

            Rectangle {
                width: 520px;
                height: min(parent.height - 80px, 540px);
                background: root.bg-surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: root.border-mid;
                TouchArea {}

                VerticalLayout {
                    padding: 20px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 10px;
                        Text {
                            text: "Browse Lens Profiles";
                            color: #fff;
                            font-size: 16px;
                            font-weight: 600;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Text { text: "Apply to:"; color: #aaa; font-size: 11px; vertical-alignment: center; }
                        ComboBox {
                            model: ["Both", "Left", "Right"];
                            current-value: root.lens-pick-side == "left" ? "Left" : root.lens-pick-side == "right" ? "Right" : "Both";
                            width: 80px;
                            selected(v) => {
                                root.lens-pick-side = v == "Left" ? "left" : v == "Right" ? "right" : "both";
                            }
                        }
                    }

                    LineEdit {
                        text <=> root.lens-search-query;
                        placeholder-text: "Search by camera, lens, resolution...";
                        edited(text) => { root.lens-search-changed(text); }
                    }

                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 2px;

                            if root.lens-search-results.length == 0 && root.lens-search-query != "": Text {
                                text: "No profiles match your search.";
                                color: #777;
                                font-size: 12px;
                            }

                            if root.lens-search-query == "": Text {
                                text: "Type to search across 4200+ camera profiles.";
                                color: #666;
                                font-size: 12px;
                            }

                            for result[idx] in root.lens-search-results: Rectangle {
                                height: 32px;
                                border-radius: 4px;
                                background: lens-row.has-hover ? #333 : #282828;

                                lens-row := TouchArea {
                                    clicked => {
                                        root.lens-pick(idx, root.lens-pick-side);
                                        root.lens-picker-open = false;
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 6px;
                                    Text {
                                        text: result;
                                        color: #ddd;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: end;
                        Button {
                            text: "Load from file...";
                            clicked => { root.lens-pick-file(); }
                        }
                        Button {
                            text: "Close";
                            clicked => { root.lens-picker-open = false; }
                        }
                    }
                }
            }
        }
    }  // close FocusScope key-scope
}
