// Reco Video Stitcher - GUI
// Material dark theme (configured via build.rs)

import { Button, VerticalBox, HorizontalBox, Slider, ProgressIndicator, LineEdit, ComboBox, CheckBox } from "std-widgets.slint";

component FileChip inherits Rectangle {
    in property <string> label;
    in property <string> file-path;
    in property <bool> has-file: file-path != "";

    callback clicked();

    height: 36px;
    border-radius: 8px;
    background: touch.has-hover ? #3a3a3a : #2a2a2a;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalBox {
        padding: 8px;
        spacing: 6px;

        Text {
            text: root.label;
            color: root.has-file ? #a0e8a0 : #aaa;
            vertical-alignment: center;
            font-size: 13px;
            font-weight: root.has-file ? 600 : 400;
        }

        if root.has-file: Text {
            text: root.file-path;
            color: #888;
            vertical-alignment: center;
            font-size: 11px;
            overflow: elide;
            horizontal-stretch: 1;
        }
    }
}

/// One labeled slider row for the controls panel.
component LabeledSlider inherits VerticalLayout {
    in property <string> label;
    in property <float> minimum;
    in property <float> maximum;
    in-out property <float> value;
    in property <string> suffix: "";
    in property <int> decimals: 2;
    callback changed(float);

    spacing: 2px;

    HorizontalLayout {
        Text {
            text: root.label;
            color: #bbb;
            font-size: 11px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        Text {
            text: (root.decimals == 0
                ? round(root.value)
                : round(root.value * 100) / 100) + root.suffix;
            color: #888;
            font-size: 11px;
            vertical-alignment: center;
        }
    }

    Slider {
        minimum: root.minimum;
        maximum: root.maximum;
        value <=> root.value;
        changed(v) => { root.changed(v); }
    }
}

export component RecoApp inherits Window {
    title: "Reco Video Stitcher";
    preferred-width: 1280px;
    preferred-height: 820px;
    min-width: 720px;
    // Prevent the transport + status bars from getting clipped at the
    // bottom. 600px = file-bar (52) + preview min (~400) + transport
    // (96) + status (28) + comfortable padding.
    min-height: 600px;
    background: #121212;

    // ── Properties bound from Rust ──

    in-out property <image> preview-frame;
    in-out property <bool> playing: false;
    in-out property <bool> files-loaded: false;
    in-out property <string> left-path: "";
    in-out property <string> right-path: "";
    in-out property <string> calibration-path: "";
    in-out property <string> status-text: "Load left + right videos and calibration JSON to begin";
    in-out property <float> progress: 0.0;
    in-out property <int> current-frame: 0;
    in-out property <int> total-frames: 0;
    in-out property <float> fps: 0.0;
    in-out property <bool> calibrating: false;
    in-out property <string> calibration-step: "";
    in-out property <bool> has-both-videos: left-path != "" && right-path != "";

    // Camera view state (kept in sync with Rust AppState).
    in-out property <float> yaw: 0.0;      // radians
    in-out property <float> pitch: 0.0;    // radians
    in-out property <float> fov: 75.0;     // degrees
    in-out property <float> blend-width: 0.05;
    in-out property <float> rig-tilt: 0.0; // degrees

    // Live calibration adjustments (PlaneLayout fields on MatchCalibration).
    // Updating these re-runs StitchPipeline::update_layout() so the user
    // can fine-tune the stitch seam without re-running auto-calibrate.
    in-out property <float> cal-intersect: 0.0;
    in-out property <float> cal-camera-axis-offset: 0.0;
    in-out property <float> cal-x-ty: 0.0;
    in-out property <bool> cal-dirty: false;  // true when user has edited

    // Controls panel visibility.
    in-out property <bool> controls-open: false;

    // Export dialog state.
    in-out property <bool> export-dialog-open: false;
    in-out property <string> export-output-path: "";
    in-out property <int> export-width: 1920;
    in-out property <int> export-height: 1080;
    in-out property <string> export-codec: "h264";
    in-out property <string> export-quality: "balanced";
    in-out property <float> export-blend-width: 0.05;
    in-out property <float> export-duration-secs: 0.0; // 0 = full clip
    in-out property <string> export-model-path: "";
    in-out property <string> export-tracking-mode: "ball";
    in-out property <int> export-detection-interval: 3;
    in-out property <bool> export-autocam-enabled: false;

    // Export progress (also used by the main status bar).
    in-out property <bool> export-in-progress: false;
    in-out property <float> export-progress: 0.0; // 0..1
    in-out property <int> export-frames-done: 0;
    in-out property <int> export-frames-total: 0;
    in-out property <string> export-status-text: "";

    // Compile-time AI capability summary. Seeded by Rust at startup
    // so the user can tell at-a-glance whether ball tracking will
    // actually work with their build (TensorRT, CUDA, CoreML, etc).
    in-out property <string> ai-status: "AI: unknown";
    in-out property <bool> ai-gpu-available: false;

    // ── Callbacks into Rust ──

    callback pick-left-video();
    callback pick-right-video();
    callback pick-calibration();
    callback auto-calibrate();
    callback toggle-playback();
    callback step-forward();
    callback step-backward();
    callback seek(float);
    // Relative seek in seconds (negative for rewind). CLI parity with `[` and `]`.
    callback seek-relative(float);
    // Mouse drag delta in pixels.
    callback pan(float, float);
    // Scroll wheel delta (degrees FOV per tick).
    callback zoom(float);
    // Reset yaw/pitch/fov to defaults.
    callback reset-view();
    // Settings-panel slider callbacks.
    callback changed-blend-width(float);
    callback changed-rig-tilt(float);
    callback changed-fov(float);
    // Live calibration editing.
    callback changed-cal-intersect(float);
    callback changed-cal-camera-axis-offset(float);
    callback changed-cal-x-ty(float);
    callback save-calibration();
    callback reset-calibration();
    // Export dialog actions.
    callback open-export-dialog();
    callback pick-export-output();
    callback pick-export-model();
    callback start-export();
    callback cancel-export();

    // Keyboard handling. The FocusScope must *wrap* the content so
    // key events have somewhere to bubble up when a child (button,
    // slider, text input) is focused. `init` grabs focus on startup
    // so shortcuts work before the user clicks anything. The
    // `refocus` callback lets Rust re-assert focus after any action
    // that a widget would otherwise steal it with.
    forward-focus: key-scope;
    public function refocus() { key-scope.focus(); }

    key-scope := FocusScope {
        // FocusScope doesn't fill its Window parent by default; the
        // VerticalBox below would render at its preferred height and
        // overflow the bottom of the window, hiding the transport
        // controls and status bar. Explicit 100/100 fixes that.
        width: 100%;
        height: 100%;
        init => { self.focus(); }
        key-pressed(event) => {
            // Space: play/pause
            if (event.text == " ") { root.toggle-playback(); return accept; }
            // Arrow keys: pan
            if (event.text == Key.LeftArrow)  { root.pan(-20, 0); return accept; }
            if (event.text == Key.RightArrow) { root.pan(20, 0);  return accept; }
            if (event.text == Key.UpArrow)    { root.pan(0, -20); return accept; }
            if (event.text == Key.DownArrow)  { root.pan(0, 20);  return accept; }
            // +/- : zoom
            if (event.text == "+" || event.text == "=") { root.zoom(-5); return accept; }
            if (event.text == "-" || event.text == "_") { root.zoom(5);  return accept; }
            // [ / ] : seek by 5s
            if (event.text == "[") { root.seek-relative(-5); return accept; }
            if (event.text == "]") { root.seek-relative(5);  return accept; }
            // R : reset view
            if (event.text == "r" || event.text == "R") { root.reset-view(); return accept; }
            return reject;
        }

        VerticalBox {
            padding: 0;
            spacing: 0;

        // ── File picker bar ──
        Rectangle {
            background: #1e1e1e;
            height: 52px;

            HorizontalBox {
                padding: 8px;
                spacing: 8px;
                alignment: start;

                FileChip {
                    label: "Left";
                    file-path: root.left-path;
                    clicked => { root.pick-left-video(); }
                }

                FileChip {
                    label: "Right";
                    file-path: root.right-path;
                    clicked => { root.pick-right-video(); }
                }

                FileChip {
                    label: "Calibration";
                    file-path: root.calibration-path;
                    clicked => { root.pick-calibration(); }
                }

                // Separator
                Rectangle { width: 1px; height: 24px; background: #444; }

                Button {
                    text: root.calibrating ? "Calibrating..." : "Auto Calibrate";
                    enabled: root.has-both-videos && !root.calibrating && !root.files-loaded;
                    clicked => { root.auto-calibrate(); }
                }

                if root.calibrating: Text {
                    text: root.calibration-step;
                    color: #8888ff;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                // Right-align spacer
                Rectangle { horizontal-stretch: 1; }

                Button {
                    text: "Export…";
                    enabled: root.files-loaded && !root.export-in-progress;
                    primary: true;
                    clicked => { root.open-export-dialog(); }
                }

                Button {
                    text: root.controls-open ? "Hide Controls" : "Controls";
                    enabled: root.files-loaded;
                    clicked => { root.controls-open = !root.controls-open; }
                }
            }
        }

        // ── Preview area + side controls ──
        HorizontalBox {
            padding: 0;
            spacing: 0;
            vertical-stretch: 1;

            // Preview (with mouse drag + scroll handling)
            Rectangle {
                background: #0a0a0a;
                horizontal-stretch: 1;

                if !root.files-loaded: Text {
                    text: root.status-text;
                    color: #666;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                if root.files-loaded: Image {
                    source: root.preview-frame;
                    image-fit: contain;
                    width: 100%;
                    height: 100%;
                }

                // Interaction layer: drag to pan, scroll to zoom.
                // `moved` fires continuously while the pointer is
                // pressed; we forward the delta to Rust which updates
                // yaw/pitch and triggers a re-render.
                drag := TouchArea {
                    enabled: root.files-loaded;
                    property <length> last-x: 0px;
                    property <length> last-y: 0px;

                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            self.last-x = self.mouse-x;
                            self.last-y = self.mouse-y;
                        }
                    }

                    moved => {
                        if (self.pressed) {
                            root.pan(
                                (self.mouse-x - self.last-x) / 1px,
                                (self.mouse-y - self.last-y) / 1px,
                            );
                            self.last-x = self.mouse-x;
                            self.last-y = self.mouse-y;
                        }
                    }

                    scroll-event(e) => {
                        // Positive delta = scroll down = zoom out.
                        // Slint scroll deltas are lengths; /1px converts
                        // to a plain number we can scale for FOV degrees.
                        root.zoom(-e.delta-y / 40px);
                        return accept;
                    }
                }
            }

            // Right-side controls panel (collapsible)
            if root.controls-open: Rectangle {
                background: #1a1a1a;
                width: 280px;
                border-width: 1px;
                border-color: #333;

                VerticalBox {
                    padding: 12px;
                    spacing: 14px;
                    alignment: start;

                    Text {
                        text: "Camera";
                        color: #fff;
                        font-size: 14px;
                        font-weight: 600;
                    }

                    LabeledSlider {
                        label: "Field of view";
                        minimum: 20;
                        maximum: 150;
                        value <=> root.fov;
                        suffix: "°";
                        decimals: 0;
                        changed(v) => { root.changed-fov(v); }
                    }

                    Rectangle { height: 1px; background: #333; }

                    Text {
                        text: "Stitching";
                        color: #fff;
                        font-size: 14px;
                        font-weight: 600;
                    }

                    LabeledSlider {
                        label: "Seam blend";
                        minimum: 0;
                        maximum: 0.3;
                        value <=> root.blend-width;
                        decimals: 2;
                        changed(v) => { root.changed-blend-width(v); }
                    }

                    LabeledSlider {
                        label: "Rig tilt";
                        minimum: -15;
                        maximum: 15;
                        value <=> root.rig-tilt;
                        suffix: "°";
                        decimals: 1;
                        changed(v) => { root.changed-rig-tilt(v); }
                    }

                    Rectangle { height: 1px; background: #333; }

                    Button {
                        text: "Reset View";
                        clicked => { root.reset-view(); }
                    }

                    Rectangle { height: 1px; background: #333; }

                    // ── Live calibration ──
                    Text {
                        text: "Calibration";
                        color: #fff;
                        font-size: 14px;
                        font-weight: 600;
                    }

                    LabeledSlider {
                        label: "Intersect";
                        minimum: -0.5;
                        maximum: 0.5;
                        value <=> root.cal-intersect;
                        decimals: 2;
                        changed(v) => { root.changed-cal-intersect(v); }
                    }

                    LabeledSlider {
                        label: "Camera axis offset";
                        minimum: -0.3;
                        maximum: 0.3;
                        value <=> root.cal-camera-axis-offset;
                        decimals: 2;
                        changed(v) => { root.changed-cal-camera-axis-offset(v); }
                    }

                    LabeledSlider {
                        label: "x_ty";
                        minimum: -0.3;
                        maximum: 0.3;
                        value <=> root.cal-x-ty;
                        decimals: 2;
                        changed(v) => { root.changed-cal-x-ty(v); }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Button {
                            text: "Save Calibration";
                            enabled: root.cal-dirty;
                            clicked => { root.save-calibration(); }
                        }
                        Button {
                            text: "Reset";
                            enabled: root.cal-dirty;
                            clicked => { root.reset-calibration(); }
                        }
                    }

                    // Keyboard hints
                    Rectangle {
                        height: 1px;
                        background: #333;
                    }

                    VerticalLayout {
                        spacing: 2px;
                        Text { text: "Shortcuts"; color: #888; font-size: 11px; font-weight: 600; }
                        Text { text: "Space  Play / pause";     color: #666; font-size: 10px; }
                        Text { text: "Arrows  Pan camera";      color: #666; font-size: 10px; }
                        Text { text: "+ / -   Zoom";            color: #666; font-size: 10px; }
                        Text { text: "Scroll  Zoom";            color: #666; font-size: 10px; }
                        Text { text: "Drag    Pan";             color: #666; font-size: 10px; }
                        Text { text: "[  ]   Seek 5 s";         color: #666; font-size: 10px; }
                        Text { text: "R      Reset view";       color: #666; font-size: 10px; }
                    }
                }
            }
        }

        // ── Transport controls ──
        Rectangle {
            background: #1e1e1e;
            height: 96px;

            VerticalBox {
                padding: 6px;
                spacing: 6px;

                // Seek slider
                HorizontalBox {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 8px;

                    Text {
                        text: root.current-frame;
                        color: #aaa;
                        font-size: 12px;
                        vertical-alignment: center;
                        width: 60px;
                    }

                    Slider {
                        horizontal-stretch: 1;
                        minimum: 0;
                        maximum: root.total-frames == 0 ? 1 : root.total-frames;
                        value: root.current-frame;
                        enabled: root.files-loaded;
                        // `released` fires only on user pointer release,
                        // unlike `changed` which also fires when Rust
                        // writes `current-frame` back after a decode
                        // (feedback loop).
                        released(val) => {
                            if root.total-frames > 0 {
                                root.seek(val / root.total-frames);
                            }
                        }
                    }

                    Text {
                        text: root.total-frames;
                        color: #aaa;
                        font-size: 12px;
                        vertical-alignment: center;
                        width: 60px;
                        horizontal-alignment: right;
                    }
                }

                // Buttons row
                HorizontalBox {
                    alignment: center;
                    spacing: 12px;

                    Button {
                        text: "|<";
                        enabled: root.files-loaded;
                        clicked => { root.step-backward(); }
                    }

                    Button {
                        text: root.playing ? "Pause" : "Play";
                        enabled: root.files-loaded;
                        clicked => { root.toggle-playback(); }
                    }

                    Button {
                        text: ">|";
                        enabled: root.files-loaded;
                        clicked => { root.step-forward(); }
                    }
                }
            }
        }

        // ── Status bar (or export progress when active) ──
        Rectangle {
            background: #181818;
            height: 28px;

            HorizontalBox {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 10px;

                if !root.export-in-progress: Text {
                    text: root.status-text;
                    color: #777;
                    font-size: 11px;
                    vertical-alignment: center;
                }

                if root.export-in-progress: Text {
                    text: "Exporting: " + root.export-status-text;
                    color: #8f8;
                    font-size: 11px;
                    vertical-alignment: center;
                    font-weight: 600;
                }

                if root.export-in-progress: ProgressIndicator {
                    progress: root.export-progress;
                    min-width: 120px;
                    horizontal-stretch: 1;
                }

                if root.export-in-progress: Button {
                    text: "Cancel";
                    clicked => { root.cancel-export(); }
                }

                if !root.export-in-progress: Rectangle { horizontal-stretch: 1; }

                if !root.export-in-progress && root.fps > 0: Text {
                    text: round(root.fps) + " fps";
                    color: #555;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }
        }  // close VerticalBox

        // ── Export dialog (modal overlay) ──
        //
        // Placed as a sibling of the main VerticalBox so it renders on
        // top. Visibility toggled by `export-dialog-open`. Clicks on
        // the dark backdrop outside the panel dismiss the dialog.
        if root.export-dialog-open: Rectangle {
            background: #000000aa; // 67% opacity scrim
            TouchArea {
                // Swallow clicks on the backdrop; clicking a transparent
                // area (not the panel) closes the dialog.
                clicked => { root.export-dialog-open = false; }
            }

            Rectangle {
                // Centered modal panel
                width: 560px;
                height: 620px;
                background: #222;
                border-radius: 12px;
                border-width: 1px;
                border-color: #444;

                // Block click-through to the backdrop.
                TouchArea {}

                VerticalBox {
                    padding: 24px;
                    spacing: 14px;

                    Text {
                        text: "Export Stitched Video";
                        color: #fff;
                        font-size: 18px;
                        font-weight: 600;
                    }

                    Text {
                        text: "Run the full pipeline (decode → stitch → encode) and save the output.";
                        color: #999;
                        font-size: 12px;
                        wrap: word-wrap;
                    }

                    // Output path
                    Text { text: "Output file"; color: #ccc; font-size: 12px; }
                    HorizontalBox {
                        spacing: 6px;
                        padding: 0;
                        LineEdit {
                            text: root.export-output-path;
                            placeholder-text: "Pick a destination file…";
                            read-only: true;
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "Save to…";
                            clicked => { root.pick-export-output(); }
                        }
                    }

                    // Resolution + codec + quality
                    HorizontalBox {
                        spacing: 10px;
                        padding: 0;

                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "Width"; color: #ccc; font-size: 12px; }
                            ComboBox {
                                model: ["1280", "1920", "2560", "3840"];
                                // ComboBox.current-value expects a string;
                                // binding an int property silently falls
                                // through to index 0 and `selected` only
                                // fires on user click. Map via current-index.
                                current-index: root.export-width == 1280 ? 0
                                             : root.export-width == 2560 ? 2
                                             : root.export-width == 3840 ? 3
                                             : 1;
                                selected(v) => {
                                    root.export-width = v == "1280" ? 1280
                                                     : v == "2560" ? 2560
                                                     : v == "3840" ? 3840
                                                     : 1920;
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "Height"; color: #ccc; font-size: 12px; }
                            ComboBox {
                                model: ["720", "1080", "1440", "2160"];
                                current-index: root.export-height == 720 ? 0
                                             : root.export-height == 1440 ? 2
                                             : root.export-height == 2160 ? 3
                                             : 1;
                                selected(v) => {
                                    root.export-height = v == "720" ? 720
                                                      : v == "1440" ? 1440
                                                      : v == "2160" ? 2160
                                                      : 1080;
                                }
                            }
                        }
                    }

                    HorizontalBox {
                        spacing: 10px;
                        padding: 0;

                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "Codec"; color: #ccc; font-size: 12px; }
                            ComboBox {
                                model: ["h264", "hevc", "av1"];
                                current-index: root.export-codec == "hevc" ? 1
                                             : root.export-codec == "av1" ? 2
                                             : 0;
                                selected(v) => { root.export-codec = v; }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            Text { text: "Quality"; color: #ccc; font-size: 12px; }
                            ComboBox {
                                model: ["fast", "balanced", "high"];
                                current-index: root.export-quality == "fast" ? 0
                                             : root.export-quality == "high" ? 2
                                             : 1;
                                selected(v) => { root.export-quality = v; }
                            }
                        }
                    }

                    // Blend + duration
                    LabeledSlider {
                        label: "Seam blend";
                        minimum: 0;
                        maximum: 0.3;
                        value <=> root.export-blend-width;
                        decimals: 2;
                        changed(v) => { /* just stored, used at submit */ }
                    }

                    Rectangle { height: 1px; background: #333; }

                    // AI Tracking section
                    HorizontalBox {
                        padding: 0;
                        spacing: 8px;
                        Text {
                            text: "AI Tracking";
                            color: #fff;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        CheckBox {
                            text: "Enable";
                            checked <=> root.export-autocam-enabled;
                            enabled: root.ai-gpu-available;
                        }
                    }

                    Text {
                        text: root.ai-status;
                        color: root.ai-gpu-available ? #8f8 : #f88;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    if root.export-autocam-enabled: VerticalLayout {
                        spacing: 8px;

                        HorizontalBox {
                            spacing: 6px;
                            padding: 0;
                            LineEdit {
                                text: root.export-model-path;
                                placeholder-text: "Pick a YOLO ONNX model…";
                                read-only: true;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: "Model…";
                                clicked => { root.pick-export-model(); }
                            }
                        }

                        HorizontalBox {
                            spacing: 10px;
                            padding: 0;

                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text { text: "Tracking mode"; color: #ccc; font-size: 12px; }
                                ComboBox {
                                    model: ["ball", "field", "sweep"];
                                    current-index: root.export-tracking-mode == "field" ? 1
                                                 : root.export-tracking-mode == "sweep" ? 2
                                                 : 0;
                                    selected(v) => { root.export-tracking-mode = v; }
                                }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text { text: "Detect every N frames"; color: #ccc; font-size: 12px; }
                                ComboBox {
                                    model: ["1", "3", "5", "10", "15", "30"];
                                    current-index: root.export-detection-interval == 1 ? 0
                                                 : root.export-detection-interval == 5 ? 2
                                                 : root.export-detection-interval == 10 ? 3
                                                 : root.export-detection-interval == 15 ? 4
                                                 : root.export-detection-interval == 30 ? 5
                                                 : 1;
                                    selected(v) => {
                                        root.export-detection-interval =
                                            v == "1" ? 1 : v == "5" ? 5 : v == "10" ? 10
                                            : v == "15" ? 15 : v == "30" ? 30 : 3;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle { vertical-stretch: 1; } // flex spacer

                    HorizontalBox {
                        spacing: 10px;
                        padding: 0;

                        Rectangle { horizontal-stretch: 1; }

                        Button {
                            text: "Cancel";
                            clicked => { root.export-dialog-open = false; }
                        }

                        Button {
                            text: "Start Export";
                            primary: true;
                            enabled: root.export-output-path != "";
                            clicked => { root.start-export(); }
                        }
                    }
                }
            }
        }
    }  // close FocusScope key-scope
}
